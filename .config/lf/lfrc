# Basic settings
set shell sh
set shellopts '-eu'
set hidden true
set icons true
set period 1
set tabstop 4
set info size
set ifs "\n"

# Image previews
set previewer ctpv
set cleaner ctpvclear
&ctpv -s $id
&ctpvquit $id

# Run shell command
map t :shell

# Movement
map gh cd ~
map gd cd ~/Downloads
map gc cd ~/.config
map gt cd ~/.local/share/Trash/files

# Open files
cmd open ${{
    case $(file --mime-type -Lb $f) in
        text/*) lf -remote "send $id \$$EDITOR \$fx";;
        audio/*) $AUDIO_PLAYER $f >/dev/null 2>&1;;
        video/*) $VIDEO_PLAYER $f >/dev/null 2>&1;;
        *) for f in $fx; do setsid -f $OPENER $f >/dev/null 2>&1; done;;
    esac
}}

# Trash
cmd tr %trash-put -- $fx
cmd tre %trash-empty
cmd trr %trash-restore
